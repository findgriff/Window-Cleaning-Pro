[Unit]
Description=RinseRun / Window Cleaning Pro API
After=network.target

[Service]
Type=simple
User=rinserun
Group=rinserun
WorkingDirectory=/opt/rinserun
EnvironmentFile=/etc/rinserun/backend.env
ExecStart=/usr/bin/python3 -m server.app
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/rinserun

[Install]
WantedBy=multi-user.target
